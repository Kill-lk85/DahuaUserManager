<Window x:Class="DahuaUserManager.UI.Windows.PhotoCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Захват фотографии"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Контроллер:"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>

            <ComboBox x:Name="ControllersBox"
                      Grid.Column="1"
                      Height="32"
                      DisplayMemberPath="IpAddress"
                      SelectionChanged="ControllersBox_SelectionChanged"/>

            <Button Grid.Column="2"
                    Content="Обновить"
                    Height="32"
                    Margin="10,0,0,0"
                    Click="RefreshFrame_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#CFCFCF"
                    BorderThickness="1"
                    Background="Black">

                <Grid>
                    <Image x:Name="LiveImage"
                           Stretch="Uniform"/>

                    <Border Width="220"
                            Height="280"
                            BorderBrush="#80FFFFFF"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    <TextBlock x:Name="LivePlaceholder"
                               Text="Видео с контроллера"
                               Foreground="White"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="16,0,0,0">

                <TextBlock Text="Снимок"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Border Width="260"
                        Height="320"
                        BorderBrush="#CFCFCF"
                        BorderThickness="1"
                        Background="#F2F2F2"
                        HorizontalAlignment="Center">

                    <Grid>
                        <Image x:Name="CapturedImage"
                               Stretch="Uniform"/>

                        <TextBlock x:Name="CapturedPlaceholder"
                                   Text="Снимок ещё не сделан"
                                   Foreground="Gray"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Button x:Name="CaptureButton"
                        Content="Сделать фото"
                        Height="40"
                        Margin="0,16,0,0"
                        Click="CaptureButton_Click"/>

                <TextBlock x:Name="StatusText"
                           Text=""
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button x:Name="OkButton"
                    Content="OK"
                    Width="110"
                    Height="34"
                    Margin="4"
                    IsEnabled="False"
                    Click="OkButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="34"
                    Margin="4"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>