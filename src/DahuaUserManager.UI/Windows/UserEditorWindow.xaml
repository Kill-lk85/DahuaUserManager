<Window x:Class="DahuaUserManager.UI.Windows.UserEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Height="740"
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="230"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,18">
            <TextBlock Text="Пользователь"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock x:Name="LastUserIdText"
                       Text="Последний UserID: —"
                       Foreground="Gray"
                       Margin="0,8,0,0"/>

            <TextBlock x:Name="LastCardText"
                       Text="Последняя карта: —"
                       Foreground="Gray"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="170"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="UserID:" VerticalAlignment="Center"/>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserIdBox"
                         Height="30"
                         TextChanged="UserIdBox_TextChanged"/>

                <Button Grid.Column="1"
                        Content="Следующий"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="UseNextUserId_Click"/>
            </Grid>

            <TextBlock Text="Имя:" Grid.Row="1" VerticalAlignment="Center"/>
            <TextBox x:Name="FullNameBox" Grid.Row="1" Grid.Column="1" Height="30"/>

            <TextBlock Text="Карта:" Grid.Row="2" VerticalAlignment="Center"/>

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="CardNumberBox" Height="30"/>

                <Button Grid.Column="1"
                        Content="= UserID"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="CardEqualsUserId_Click"/>
            </Grid>

           
            <TextBlock Text="Начало:" Grid.Row="4" VerticalAlignment="Center"/>
            <DatePicker x:Name="ValidFromPicker" Grid.Row="4" Grid.Column="1" Height="30"/>

            <TextBlock Text="Конец:" Grid.Row="5" VerticalAlignment="Center"/>
            <DatePicker x:Name="ValidToPicker" Grid.Row="5" Grid.Column="1" Height="30"/>

            <TextBlock Text="Активен:" Grid.Row="6" VerticalAlignment="Center"/>
            <CheckBox x:Name="IsValidBox" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center"/>
            <GroupBox Header="Контроллеры"
          Grid.Row="7"
          Grid.ColumnSpan="2"
          Margin="0,10,0,0">

                <DockPanel Margin="6">

                    <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

                        <Button x:Name="SelectAllControllersButton"
                    Width="100"
                    Margin="3"
                    Content="Все"/>

                        <Button x:Name="ClearControllersButton"
                    Width="100"
                    Margin="3"
                    Content="Очистить"/>

                    </StackPanel>

                    <ListBox x:Name="ControllersListBox">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <CheckBox
                        Content="{Binding Name}"
                        IsChecked="{Binding UseByDefault}"/>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </DockPanel>

            </GroupBox>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="1"
                BorderBrush="#CFCFCF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="18,0,0,0"
                Background="White">

            <StackPanel>
                <TextBlock Text="Фото"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Border Width="190"
                        Height="230"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        Background="#F2F2F2"
                        HorizontalAlignment="Center">

                    <Grid>
                        <Image x:Name="PhotoPreview"
                               Stretch="Uniform"/>

                        <TextBlock x:Name="NoPhotoText"
                                   Text="Нет фото"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Button Content="Выбрать фото..."
                        Height="34"
                        Margin="0,12,0,0"
                        Click="SelectPhoto_Click"/>

                <Button Content="Захват с контроллера"
                        Height="34"
                        Margin="0,6,0,0"
                        Click="CapturePhotoFromController_Click"/>

                <Button Content="Очистить"
                        Height="34"
                        Margin="0,6,0,0"
                        Click="ClearPhoto_Click"/>

                <TextBlock x:Name="PhotoPathText"
                           Text=""
                           TextWrapping="Wrap"
                           Foreground="Gray"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">

            <Button Content="Сохранить"
                    Width="110"
                    Height="34"
                    Margin="4"
                    Click="Save_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="34"
                    Margin="4"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>