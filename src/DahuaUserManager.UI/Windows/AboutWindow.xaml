<Window x:Class="DahuaUserManager.UI.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        Width="620"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Dahua User Manager"
                       FontSize="26"
                       FontWeight="Bold"/>

            <TextBlock Text="Версия 1.0.0"
                       Foreground="Gray"
                       Margin="0,6,0,14"/>
        </StackPanel>

        <ScrollViewer
                      VerticalScrollBarVisibility="Auto" Margin="0,61,0,10" Grid.RowSpan="2">

            <TextBlock TextWrapping="Wrap"
                       FontSize="14"
                       LineHeight="22"><Run Text="Назначение&#x0a;&#x0a;"/><Run Text="Dahua User Manager предназначен для централизованного управления пользователями, картами доступа и фотографиями на контроллерах доступа Dahua.&#x0a;&#x0a;"/><Run Text="Программа разработана как лёгкая и быстрая альтернатива SmartPSS для повседневной работы с несколькими контроллерами одновременно.&#x0a;&#x0a;"/><Run Text="Основные возможности&#x0a;&#x0a;"/><Run Text="• Управление несколькими контроллерами Dahua.&#x0a;"/><Run Text="• Автоматическое определение поддерживаемого API контроллера.&#x0a;"/><Run Text="• Создание пользователей.&#x0a;"/><Run Text="• Редактирование пользователей.&#x0a;"/><Run Text="• Назначение и изменение карт доступа.&#x0a;"/><Run Text="• Загрузка фотографий лиц.&#x0a;"/><Run Text="• Захват фотографии непосредственно с камеры контроллера.&#x0a;"/><Run Text="• Одновременное создание пользователей на нескольких контроллерах.&#x0a;"/><Run Text="• Удаление пользователей с выбранного контроллера.&#x0a;"/><Run Text="• Удаление пользователей сразу со всех контроллеров.&#x0a;"/><Run Text="• Автоматическое сохранение списка контроллеров.&#x0a;"/><Run Text="• Автоматическое сохранение расположения и ширины колонок.&#x0a;&#x0a;"/><Run Text="Используемые технологии&#x0a;&#x0a;"/><Run Text="Для обмена данными используются стандартные сетевые интерфейсы контроллеров Dahua:&#x0a;&#x0a;"/><Run Text="• HTTP Digest Authentication&#x0a;"/><Run Text="• CGI API&#x0a;"/><Run Text="• RPC2 API&#x0a;&#x0a;"/><Run Text="Программа работает без использования Dahua SDK и не требует установки дополнительных библиотек производителя.&#x0a;&#x0a;"/><Run Text="Совместимость&#x0a;&#x0a;"/><Run Text="Программа протестирована на контроллерах серии DHI-ASI6213S-PW.&#x0a;&#x0a;"/><Run Text="Совместима с современными прошивками Dahua, поддерживающими RPC2 API.&#x0a;&#x0a;"/><Run Text="Особенности&#x0a;&#x0a;"/><Run Text="Все операции выполняются непосредственно на контроллерах.&#x0a;&#x0a;"/><Run Text="Программа не использует облачные сервисы, промежуточные серверы или сторонние базы данных.&#x0a;&#x0a;"/><Run Text="Разработчик: Из прекрасного города Караганда Kill_l email: Predator_l@mail.ru для себя и поделюсь &#x0a;"/><Run Text="Все права защищены.&#x0a;"/><Run Text="© 2026"/></TextBlock>

        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Закрыть"
                Width="110"
                Height="34"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>