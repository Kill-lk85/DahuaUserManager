<Window x:Class="DahuaUserManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dahua User Manager"
        Height="760"
        Width="1250"
        WindowStartupLocation="CenterScreen">

    <DockPanel Background="#F5F5F5">

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов"/>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left"
                Width="300"
                Background="#ECECEC"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="12">

                <TextBlock Text="Контроллеры"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <ListBox x:Name="ControllersList"
                         Height="150"
                         DisplayMemberPath="Name"
                         SelectionChanged="ControllersList_SelectionChanged"/>

                <TextBlock Text="IP нового контроллера"
                           Margin="0,12,0,4"/>

                <TextBox x:Name="NewControllerIpBox"
                         Height="32"
                         Text="192.168.0."/>

                <Button Content="Добавить контроллер"
                        Height="38"
                        Margin="0,8,0,0"
                        Click="AddController_Click"/>

                <Separator Margin="0,15"/>

                <Button Content="Обновить пользователей"
                        Height="42"
                        Margin="0,5"
                        Click="RefreshUsers_Click"/>

                <Button Content="Удалить выбранного с текущего"
                        Height="42"
                        Margin="0,5"
                        Click="DeleteSelected_Click"/>

                <Button Content="Удалить выбранного со всех"
                        Height="42"
                        Margin="0,5"
                        Click="DeleteSelectedFromAll_Click"/>

            </StackPanel>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderText"
                       Text="Пользователи"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Height="32"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="CountText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="Записей: 0"/>
            </Grid>

            <DataGrid x:Name="UsersGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="RecNo" Binding="{Binding RecNo}" Width="80"/>
                    <DataGridTextColumn Header="UserID" Binding="{Binding UserId}" Width="100"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding CardName}" Width="*"/>
                    <DataGridTextColumn Header="Карта" Binding="{Binding CardNo}" Width="140"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding CardStatus}" Width="100"/>
                    <DataGridTextColumn Header="Действует" Binding="{Binding IsValid}" Width="100"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding ValidDateStart}" Width="160"/>
                    <DataGridTextColumn Header="Конец" Binding="{Binding ValidDateEnd}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </DockPanel>
</Window>