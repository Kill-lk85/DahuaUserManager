<Window x:Class="DahuaUserManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dahua User Manager"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">

	<DockPanel>

		<!-- Строка состояния -->
		<StatusBar DockPanel.Dock="Bottom">
			<StatusBarItem>
				<TextBlock Text="Готов"/>
			</StatusBarItem>
		</StatusBar>

		<!-- Меню слева -->
		<Border DockPanel.Dock="Left"
                Width="220"
                Background="#F2F2F2">

			<StackPanel Margin="10">

				<TextBlock Text="Dahua User Manager"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

				<Button Content="Контроллеры" Height="40" Margin="0,5"/>
				<Button Content="Пользователи" Height="40" Margin="0,5"/>
				<Button Content="Лица" Height="40" Margin="0,5"/>
				<Button Content="Карты" Height="40" Margin="0,5"/>
				<Button Content="Журнал" Height="40" Margin="0,5"/>
				<Button Content="Настройки" Height="40" Margin="0,5"/>
				<Button Content="Проверить контроллер"
        Height="40"
        Margin="0,20,0,0"
        Click="CheckController_Click"/>
			</StackPanel>

		</Border>

		<!-- Рабочая область -->
		<Grid Margin="10">

			<TextBlock Text="Добро пожаловать в Dahua User Manager"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

		</Grid>

	</DockPanel>

</Window>