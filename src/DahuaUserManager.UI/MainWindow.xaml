<Window x:Class="DahuaUserManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dahua User Manager"
        Height="760"
        Width="1250"
        WindowStartupLocation="CenterScreen">

    <DockPanel Background="#F5F5F5">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Контроллеры">
                <MenuItem Header="Управление..." Click="OpenControllerManager_Click"/>
            </MenuItem>

            <MenuItem Header="Пользователи">
                <MenuItem Header="Новый пользователь..." Click="NewUser_Click"/>
                <MenuItem Header="Изменить..." Click="EditUser_Click"/>
                <Separator/>
                <MenuItem Header="Удалить с текущего" Click="DeleteSelected_Click"/>
                <MenuItem Header="Удалить со всех" Click="DeleteSelectedFromAll_Click"/>
            </MenuItem>

            <MenuItem Header="Справка">
                <MenuItem Header="О программе..." Click="About_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов"/>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left"
                Width="300"
                Background="#ECECEC"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="12">

                <TextBlock Text="Контроллеры"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <ListBox x:Name="ControllersList"
                         Height="260"
                         DisplayMemberPath="Name"
                         SelectionChanged="ControllersList_SelectionChanged"/>

                <Separator Margin="0,15"/>

                <Button Content="Управление контроллерами..."
                        Height="38"
                        Margin="0,5"
                        Click="OpenControllerManager_Click"/>

            </StackPanel>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderText"
                       Text="Пользователи"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <ToolBar Grid.Row="1" Margin="0,0,0,10">
                <Button Content="➕ Новый"
                        Padding="10,4"
                        Click="NewUser_Click"/>

                <Button Content="✏ Изменить"
                        Padding="10,4"
                        Click="EditUser_Click"/>

                <Separator/>

                <Button Content="📷 Фото"
                        Padding="10,4"
                        Click="UserPhoto_Click"/>

                <Separator/>

                <Button Content="🗑 Удалить"
                        Padding="10,4"
                        Click="DeleteSelected_Click"/>

                <Button Content="🗑 Со всех"
                        Padding="10,4"
                        Click="DeleteSelectedFromAll_Click"/>

                <Separator/>

                <Button Content="🔄 Обновить"
                        Padding="10,4"
                        Click="RefreshUsers_Click"/>
            </ToolBar>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Height="32"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="CountText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="Записей: 0"/>
            </Grid>

            <DataGrid x:Name="UsersGrid"
                      Grid.Row="3"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Новый пользователь..." Click="NewUser_Click"/>
                        <MenuItem Header="Изменить..." Click="EditUser_Click"/>
                        <Separator/>
                        <MenuItem Header="Фото..." Click="UserPhoto_Click"/>
                        <Separator/>
                        <MenuItem Header="Удалить с текущего" Click="DeleteSelected_Click"/>
                        <MenuItem Header="Удалить со всех" Click="DeleteSelectedFromAll_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="RecNo" Binding="{Binding RecNo}" Width="80"/>
                    <DataGridTextColumn Header="UserID" Binding="{Binding UserId}" Width="100"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding CardName}" Width="*"/>
                    <DataGridTextColumn Header="Карта" Binding="{Binding CardNo}" Width="140"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding CardStatus}" Width="100"/>
                    <DataGridTextColumn Header="Действует" Binding="{Binding IsValid}" Width="100"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding ValidDateStart}" Width="160"/>
                    <DataGridTextColumn Header="Конец" Binding="{Binding ValidDateEnd}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </DockPanel>
</Window>